    "def _count_smaller_element(nums:list, n:int)->int:\n",
    "    List=[i for i in nums if i<n]\n",
    "    return len(List)\n",
    "\n",
    "print(_count_smaller_element(nums=[1,2,3,4,5,6,7], n=5))"
   ]
  }

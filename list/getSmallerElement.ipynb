   "source": [
    "# Get smaller element from a list\n",
    "def _get_smaller_element(nums:list, n:int):\n",
    "    List=[i for i in nums if i<n]\n",
    "    return List\n",
    "\n",
    "print(_get_smaller_element([8, 100, 20,40,3,7],10)) \n",
    "# time complexity: O(n)"
   ]
  }
 ],

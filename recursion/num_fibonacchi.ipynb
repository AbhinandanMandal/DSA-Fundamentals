   "source": [
    "def num_fibonacchi(n:int):\n",
    "    if(n==0):\n",
    "        return 0\n",
    "    if(n==1):\n",
    "        return 1\n",
    "    return num_fibonacchi(n-1)+num_fibonacchi(n-2)\n",
    "\n",
    "print(num_fibonacchi(5))\n",
    "# Time complexity: O(2^n). exponential time complexity\n",
    "# Space complexity: O(n)\n"
   ]
  }
 ],

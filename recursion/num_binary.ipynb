   "source": [
    "def _num_binary(n:int):\n",
    "    if n==0:\n",
    "        return \n",
    "    _num_binary(n//2)\n",
    "    print(n%2, end=\"\")\n",
    "\n",
    "_num_binary(12)\n",
    "_num_binary(15)\n",
    "\n",
    "# Time complexity: O(logn)\n",
    "# Space complexity: O(logn)"
   ]
  }
 ],

   "source": [
    "def _num_sum(n:int):\n",
    "    if n<=1:\n",
    "        return n\n",
    "    return n+_num_sum(n-1)\n",
    "\n",
    "print(_num_sum(5))\n",
    "# Time complexity: O(n)\n",
    "# Space complexity: O(n)"
   ]
  }
 ],

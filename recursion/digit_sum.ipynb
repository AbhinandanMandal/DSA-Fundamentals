   "source": [
    "def _digit_sum(n:int):\n",
    "    if n<10:\n",
    "        return n\n",
    "    return n%10+_digit_sum(n//10)\n",
    "\n",
    "print(_digit_sum(123))\n",
    "print(_digit_sum(234))\n",
    "print(_digit_sum(100))\n",
    "\n",
    "# Time complexity: O(logn)\n",
    "# Space complexity: o(logn), casuse recursion depth equals to number of digits\n"
   ]
  }
 ],

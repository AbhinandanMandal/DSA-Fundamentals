   "source": [
    "def reverse_sentence(s:str):\n",
    "    str_list=s.split()\n",
    "    reverse_list=str_list[::-1]\n",
    "    return \" \".join(reverse_list)\n",
    "\n",
    "print(reverse_sentence(\"I love computer vision\"))\n",
    "\n",
    "# Time complexity: O(n)"
   ]
  }

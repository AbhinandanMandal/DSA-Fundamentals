   "source": [
    "# welcome to india -> india to welcome\n",
    "\n",
    "def reverse_words(s:str):\n",
    "    s_list=s.split()\n",
    "    rs_list=s_list[::-1]\n",
    "    return \" \".join(rs_list)\n",
    "\n",
    "s = 'welcome to india'\n",
    "# s='abc'\n",
    "print(reverse_words(s=s))\n",
    "# time complexity: O(n)"
   ]
  }
 ],
